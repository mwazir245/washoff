WASHOFF_ENV="dev"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/washoff?schema=public"
DATABASE_URL_QA="postgresql://postgres:postgres@localhost:5432/washoff_qa?schema=public"

VITE_WASHOFF_DATA_SOURCE="api"
VITE_WASHOFF_API_BASE_URL="/api/platform"
VITE_WASHOFF_DEFAULT_HOTEL_ID="hotel-1"
VITE_WASHOFF_DEFAULT_PROVIDER_ID="provider-1"

WASHOFF_SERVER_PERSISTENCE_MODE="db"
WASHOFF_FILE_DATA_PATH="data/washoff-platform.json"
WASHOFF_ENABLE_WORKER="false"
WASHOFF_WORKER_POLL_INTERVAL_MS="30000"
WASHOFF_ENABLE_REQUEST_TIME_SWEEP="false"
WASHOFF_AUTH_MODE="dev-header"
WASHOFF_INTERNAL_API_KEY="washoff-dev-internal-key"
WASHOFF_PUBLIC_APP_URL="http://localhost:8080"
WASHOFF_MAIL_MODE="outbox"
WASHOFF_MAIL_OUTBOX_PATH="data/mail-outbox"
WASHOFF_MAIL_FROM_EMAIL="washoff@outlook.sa"
WASHOFF_MAIL_FROM_NAME_AR="منصة WashOff"
WASHOFF_MAIL_RETRY_MAX_ATTEMPTS="3"
WASHOFF_MAIL_RETRY_BASE_DELAY_MS="500"
WASHOFF_WEB_PORT="8080"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
WASHOFF_SERVER_HOST="0.0.0.0"
WASHOFF_SERVER_PORT="8787"
