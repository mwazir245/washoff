WASHOFF_ENV="qa"
DATABASE_URL_QA="postgresql://postgres:postgres@localhost:5432/washoff_qa?schema=public"

VITE_WASHOFF_DATA_SOURCE="api"
VITE_WASHOFF_API_BASE_URL="/api/platform"
WASHOFF_SERVER_PERSISTENCE_MODE="db"
WASHOFF_AUTH_MODE="session-or-dev-header"
WASHOFF_ENABLE_WORKER="false"
WASHOFF_ENABLE_REQUEST_TIME_SWEEP="false"
WASHOFF_MAIL_MODE="outbox"
WASHOFF_MAIL_OUTBOX_PATH="data/mail-outbox-qa"
WASHOFF_MAIL_FROM_EMAIL="washoff@outlook.sa"
WASHOFF_MAIL_FROM_NAME_AR="منصة WashOff"
WASHOFF_FILE_DATA_PATH="data/washoff-platform.qa.json"
WASHOFF_PUBLIC_APP_URL="http://localhost:8081"
WASHOFF_INTERNAL_API_KEY="washoff-qa-internal-key"
WASHOFF_WEB_PORT="8081"
WASHOFF_SERVER_PORT="8788"
